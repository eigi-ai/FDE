    {
      "name": "Authentication",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  let response = {};",
                  "  try { response = pm.response.json(); } catch (error) {}",
                  "  if (response.user && response.user.access_token) {",
                  "    pm.collectionVariables.set('accessToken', response.user.access_token);",
                  "  }",
                  "  if (response.user && response.user.id) {",
                  "    pm.collectionVariables.set('userId', response.user.id);",
                  "  }",
                  "  if (response.user && response.user.user_role === 'ADMIN' && response.user.access_token) {",
                  "    pm.collectionVariables.set('adminAccessToken', response.user.access_token);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Mrunmay\",\n  \"last_name\": \"Chichkhede\",\n  \"email\": \"mchichkhede2002@gmail.com\",\n  \"password\": \"P@ssw0rd\",\n  \"mobile_number\": \"9156685436\",\n  \"user_address\": {\n    \"street\": \"Mahuli road\",\n    \"city\": \"Ramtek\",\n    \"state\": \"Maharashtra\",\n    \"postal_code\": \"441401\",\n    \"country\": \"India\"\n  }\n}"
            },
